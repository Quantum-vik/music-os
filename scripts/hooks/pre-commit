#!/usr/bin/env bash
# Fast pre-commit gate: formatting + layer rule. Full lint/test runs in CI and
# via `just ci`. Bypass in emergencies with `git commit --no-verify`.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

cargo fmt --all --check || {
    echo "pre-commit: formatting check failed — run 'just fmt'" >&2
    exit 1
}
python3 scripts/check_layers.py
